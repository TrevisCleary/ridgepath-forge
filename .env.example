# RidgePath Ops hosted access gate.
# Set these in Vercel Project Settings > Environment Variables.
OPS_AUTH_USERNAME=
OPS_AUTH_PASSWORD=

# Command-center storage.
COMMAND_CENTER_DATABASE_URL=

# Optional local runner identity. Defaults to the Windows hostname.
RIDGEPATH_RUNNER_ID=
RIDGEPATH_RUNNER_NAME=
RIDGEPATH_RUNNER_QUEUE_SECONDS=60
RIDGEPATH_LOCAL_FORGE_API=http://127.0.0.1:3059
